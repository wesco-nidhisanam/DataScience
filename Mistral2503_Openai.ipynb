   "source": [
    "from pydantic import BaseModel, Field, field_validator\n",
    "from typing import Optional, List, Union\n",
    "from enum import Enum\n",
    "\n",
    "# Load environment variables\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv()\n",
    "\n",
    "\n",
    "class QtyEnum(str, Enum):\n",
    "    \"\"\"Enumeration for Quantity related source field values.\n",
    "    \n",
    "    Maps various quantity field names from different data sources to standardized values.\n",
    "    Used to track the original source field name for data lineage and debugging.\n",
    "    \"\"\"\n",
    "    QTY = \"qty\"\n",
    "    VOLUME = \"volume\"\n",
    "    QUANTITY = \"quantity\"\n",
    "    AMOUNT = \"amount\"\n",
    "    QUANTITY_ORDERED = \"quantity_ordered\"\n",
    "\n",
    "\n",
    "class Qty(BaseModel):\n",
    "    \"\"\"Represents quantity information with source field tracking.\n",
    "    \n",
    "    Handles various quantity formats and maintains data lineage by tracking\n",
    "    the original source field name. Supports flexible input validation to\n",
    "    accommodate different data quality scenarios.\n",
    "    \"\"\"\n",
    "    \n",
    "    value: Optional[int | float] = Field(\n",
    "        default=None,\n",
    "        description=\"The numeric quantity value. Can be None for missing/invalid data. \"\n",
    "                   \"Represents count, volume, or amount depending on context.\",\n",
    "        examples=[1, 10, 100, 0.5, None],\n",
    "        ge=0  # Allow 0 but not negative, flexible for edge cases\n",
    "    )\n",
    "    \n",
    "    source: str = Field(\n",
    "        default=\"qty\",\n",
    "        description=\"The original source field name from which this quantity was extracted. \"\n",
    "                   \"Used for data lineage tracking and debugging. Automatically normalized \"\n",
    "                   \"to lowercase with underscores replacing spaces.\",\n",
    "        examples=[\"qty\", \"quantity\", \"volume\", \"amount\", \"quantity_ordered\"]\n",
    "    )\n",
    "\n",
    "    @field_validator('source', mode='before')\n",
    "    @classmethod\n",
    "    def normalize_source(cls, v):\n",
    "        \"\"\"Normalize source field names to consistent format.\"\"\"\n",
    "        if not v:\n",
    "            return \"qty\"\n",
    "        return str(v).lower().replace(\" \", \"_\").strip()\n",
    "\n",
    "    @field_validator('value', mode='before')\n",
    "    @classmethod\n",
    "    def handle_empty_value(cls, v):\n",
    "        \"\"\"Handle empty, None, or invalid quantity values flexibly.\"\"\"\n",
    "        if v is None or v == \"\":\n",
    "            return None\n",
    "        if isinstance(v, str):\n",
    "            v = v.strip()\n",
    "            if not v or v.lower() in ['n/a', 'na', 'none', 'null']:\n",
    "                return None\n",
    "            try:\n",
    "                return float(v)  # Handle decimal strings that represent whole numbers\n",
    "            except (ValueError, TypeError):\n",
    "                return None\n",
    "        try:\n",
    "            return v if v is not None else None\n",
    "        except (ValueError, TypeError):\n",
    "            return None\n",
    "\n",
    "    @classmethod\n",
    "    def from_any_source(cls, value: Union[int, str, None], source_name: str = None):\n",
    "        \"\"\"Create Qty instance from any source with flexible value handling.\n",
    "        \n",
    "        Args:\n",
    "            value: The quantity value (int, string representation, or None)\n",
    "            source_name: Original field name from data source\n",
    "            \n",
    "        Returns:\n",
    "            Qty instance with normalized source name and validated value\n",
    "        \"\"\"\n",
    "        if source_name:\n",
    "            source_name_lower = source_name.lower().replace(\" \", \"_\").strip()\n",
    "            # Check known synonyms first\n",
    "            for enum_val in QtyEnum:\n",
    "                if enum_val.value.lower() == source_name_lower:\n",
    "                    return cls(value=value, source=enum_val.value)\n",
    "            \n",
    "            # Accept unknown source names for flexibility\n",
    "            return cls(value=value, source=source_name_lower)\n",
    "        \n",
    "        return cls(value=value, source=\"qty\")\n",
    "\n",
    "\n",
    "class TypeEnum(str, Enum):\n",
    "    \"\"\"Enumeration for Type/Category related source field values.\n",
    "    \n",
    "    Standardizes different ways item types or categories are represented\n",
    "    across various data sources and document formats.\n",
    "    \"\"\"\n",
    "    TYPE = \"type\"\n",
    "    CATEGORY = \"category\"\n",
    "    DESIGNATION = \"designation\"\n",
    "    DESCRIPTION = \"description\"\n",
    "\n",
    "\n",
    "class Type(BaseModel):\n",
    "    \"\"\"Represents the type, category, or classification of an item.\n",
