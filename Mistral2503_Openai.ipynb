    "    SUBTOTAL = \"subtotal\"\n",
    "    SUB_TOTAL = \"sub_total\"\n",
    "    TOTAL = \"Total\"\n",
    "    LOT_TOTAL = \"lot_total\"\n",
    "    GROUP_TOTAL = \"group_total\"\n",
    "    GRAND_TOTAL= \"Grand Total\"\n",
    "\n",
    "\n",
    "class LotSubtotal(BaseModel):\n",
    "    \"\"\"Represents a subtotal amount for a group of items in a lot.\n",
    "    \n",
    "    Captures the total pricing for a collection of related items\n",
    "    that are priced as a group rather than individually.\n",
    "    \"\"\"\n",
    "    \n",
    "    value: Optional[str] = Field(\n",
    "        default=None,\n",
    "        description=\"The subtotal amount for the lot as a string to preserve formatting. \"\n",
    "                   \"Represents the total cost for all items in this lot grouping. \"\n",
    "                   \"Can include currency symbols or be None for missing subtotals.\",\n",
    "        examples=[\"$225,951.96\", \"1500.00\", \"N/A\", None]\n",
    "    )\n",
    "    \n",
    "    source: LotSubtotalEnum = Field(\n",
    "        default=LotSubtotalEnum.SUBTOTAL,\n",
    "        description=\"The original source field name for subtotal information \"\n",
    "                   \"(subtotal, total, lot_total, etc.)\",\n",
    "        examples=[\"subtotal\",\"Total\" \"lot_total\", \"group_total\"]\n",
    "    )\n",
    "\n",
    "    @field_validator('value', mode='before')\n",
    "    @classmethod\n",
    "    def handle_empty_value(cls, v):\n",
    "        \"\"\"Handle empty, None, or invalid subtotal values.\"\"\"\n",
    "        if v is None:\n",
    "            return None\n",
    "        if isinstance(v, str):\n",
    "            v = v.strip()\n",
    "            if not v or v.lower() in ['n/a', 'na', 'tbd', 'none', 'null']:\n",
    "                return None\n",
    "        return str(v) if v is not None else None\n",
    "    \n",
    "\n",
