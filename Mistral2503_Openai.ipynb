    "\n",
    "# --- Item and Table Models ---\n",
    "\n",
    "class Item(BaseModel):\n",
    "    \"\"\"Represents a single item or line entry in a procurement/description table.\n",
    "    \n",
    "    Encapsulates all information related to a single line item including\n",
    "    quantities, pricing, identification, and associated notes. Designed\n",
    "    to handle data from various source formats with flexible validation.\n",
    "    \"\"\"\n",
    "    \n",
    "    qty: Qty = Field(\n",
    "        description=\"Quantity information including the numeric value and source field name. \"\n",
