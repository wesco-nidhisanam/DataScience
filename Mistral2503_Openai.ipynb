    "        default=None,\n",
    "        description=\"The item type, category, or classification. Can be None for unspecified types. \"\n",
    "                   \"Examples include product categories, service types, or item classifications.\",\n",
    "        examples=[\"Hardware\", \"Software\", \"Service\", \"Material\", \"Equipment\", None]\n",
    "    )\n",
    "    \n",
    "    source: TypeEnum = Field(\n",
    "        default=TypeEnum.TYPE,\n",
    "        description=\"The original source field name indicating how this type information was labeled \"\n",
    "                   \"in the source data (type, category, designation, etc.)\",\n",
    "        examples=[\"type\", \"category\", \"designation\", \"description\"]\n",
    "    )\n",
    "\n",
    "    @field_validator('value', mode='before')\n",
    "    @classmethod\n",
    "    def handle_empty_value(cls, v):\n",
    "        \"\"\"Handle empty or None type values.\"\"\"\n",
    "        if not v or (isinstance(v, str) and not v.strip()):\n",
