    "\n",
    "class PartNumber(BaseModel):\n",
    "    \"\"\"Represents the part number, item identifier, or product code.\n",
    "    \n",
    "    Captures various forms of item identification including part numbers,\n",
    "    catalog numbers, product codes, and descriptive identifiers.\n",
    "    \"\"\"\n",
    "    \n",
    "    value: Optional[str] = Field(\n",
    "        default=None,\n",
    "        description=\"The part number, item identifier, product code, or catalog number. \"\n",
    "                   \"Can be None for items without specific part numbers. May include \"\n",
    "                   \"alphanumeric codes, model numbers, or descriptive identifiers.\",\n",
    "        examples=[\"ABC-123\", \"DELL-LAPTOP-001\", \"N/A\", \"TBD\", None]\n",
    "    )\n",
    "    \n",
    "    source: PartNumberEnum = Field(\n",
    "        default=PartNumberEnum.PART_NUMBER,\n",
    "        description=\"The original source field name for part number information. \"\n",
    "                   \"Tracks whether this came from part_number, catalog_number, description, etc.\",\n",
    "        examples=[\"part_number\", \"catalog_number\", \"item_id\", \"description\"]\n",
    "    )\n",
    "\n",
    "    @field_validator('value', mode='before')\n",
    "    @classmethod\n",
    "    def handle_empty_value(cls, v):\n",
    "        \"\"\"Handle empty, None, or placeholder part number values.\"\"\"\n",
    "        if not v or (isinstance(v, str) and not v.strip()):\n",
    "            return None\n",
    "        v_str = str(v).strip()\n",
    "        # Handle common placeholder values\n",
    "        if v_str.lower() in ['n/a', 'na', 'tbd', 'none', 'null', 'unknown']:\n",
    "            return None\n",
    "        return v_str\n",
    "\n",
    "\n",
    "class UnitPriceEnum(str, Enum):\n",
    "    \"\"\"Enumeration for Unit Price related source field values.\n",
    "    \n",
    "    Maps various pricing field names from different procurement systems,\n",
    "    invoices, and quotation documents.\n",
    "    \"\"\"\n",
    "    UNIT_PRICE = \"unit_price\"\n",
    "    UNIT_DOLLAR = \"unit_dollar\"\n",
    "    NET_UNIT_PRICE = \"net_unit_price\"\n",
    "    RATE = \"rate\"\n",
    "    PRICE_EACH = \"price_each\"\n",
    "    RATE_PER_ITEM = \"rate_per_item\"\n",
    "    UNIT_SELL = \"Unit Sell\"\n",
    "\n",
    "\n",
