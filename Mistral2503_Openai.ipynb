    "\n",
    "\n",
    "class PartNumberEnum(str, Enum):\n",
    "    \"\"\"Enumeration for Part Number related source field values.\n",
    "    \n",
    "    Comprehensive mapping of different ways part numbers, item identifiers,\n",
    "    and product codes are labeled across various systems and documents.\n",
