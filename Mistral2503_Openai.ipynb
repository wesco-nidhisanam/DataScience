   "source": [
    "values_only = []\n",
    "lots_only = []\n",
    "\n",
    "# Process individual items\n",
    "for item in item_json_data.get('items', []):\n",
    "    clean_item = {\n",
    "        'qty': item['qty']['value'] if item.get('qty') else None,\n",
    "        'type': item['type']['value'] if item.get('type') else None,\n",
    "        'mfr': item['mfr']['value'] if item.get('mfr') else None,\n",
    "        'partNumber': item['partNumber']['value'] if item.get('partNumber') else None,\n",
    "        'unitPrice': item['unitPrice']['value'] if item.get('unitPrice') else None,\n",
    "        'um': item['um']['value'] if item.get('um') else None,\n",
    "        'extPrice': item['extPrice']['value'] if item.get('extPrice') else None,\n",
    "        'lineNote': item['lineNote']['value'] if item.get('lineNote') else None,\n",
    "        'leadTime': item['leadTime']['value'] if item.get('leadTime') and item['leadTime'] else None    \n",
    "    }\n",
    "    values_only.append(clean_item)\n",
    "\n",
    "# Process lots\n",
    "for lot in lot_json_data.get('lots', []):\n",
    "    clean_lot_items = []\n",
    "    \n",
    "    # Process items within each lot\n",
    "    for item in lot.get('items', []):\n",
    "        clean_item = {\n",
    "            'qty': item['qty']['value'] if item.get('qty') else None,\n",
    "            'type': item['type']['value'] if item.get('type') else None,\n",
    "            'mfr': item['mfr']['value'] if item.get('mfr') else None,\n",
    "            'MFRpartNumber': item['MFRpartNumber']['value'] if item.get('MFRpartNumber') else None,\n",
    "            'lineNote': item['lineNote']['value'] if item.get('lineNote') else None,\n",
    "            'leadTime': item['leadTime']['value'] if item.get('leadTime') and item['leadTime'] else None,\n",
    "            }\n",
    "        clean_lot_items.append(clean_item)\n",
    "    \n",
    "    # Build the clean lot structure\n",
    "    clean_lot = {\n",
    "        'identifier': lot['identifier']['value'] if lot.get('identifier') else None,\n",
    "        'items': clean_lot_items,\n",
    "        'subtotal': lot['subtotal']['value'] if lot.get('subtotal') else None,\n",
    "        'lot_notes': lot.get('lot_notes', None)\n",
    "    }\n",
    "    lots_only.append(clean_lot)\n",
    "\n",
    "\n",
    "customer_notes_only= [lot_json_data.get('customerNote', {}).get('value') if lot_json_data.get('customerNote', {}).get('value') else None\n",
    "]   \n",
    "\n",
    "# Print the cleaned data structure\n",
    "print(\"\\n--- Values Only (extracted from JSON response) ---\")\n",
    "cleaned_data = {\n",
    "    'items': values_only,\n",
    "    'lots': lots_only,\n",
    "    'customerNote': customer_notes_only\n",
    "}\n",
    "print(json.dumps(cleaned_data, indent=4))"
   ]
