    "class LotSubtotalEnum(str, Enum):\n",
    "    \"\"\"Enumeration for Lot Subtotal related source field values.\n",
    "    \n",
    "    Maps various subtotal field names from different systems\n",
    "    that represent grouped pricing information.\n",
