    "root_agent = Agent(\n",
    "    model=\"gemini-2.5-pro\",\n",
    "    name=\"qpm_workflow_agent\",\n",
    "    description=\"Main workflow coordinator\",\n",
    "    instruction=\"\"\"\n",
    "    You are the workflow coordinator. Strictly follow below order:\n",
    "\n",
    "    1. Call `call_summary_agent()`\n",
    "    2. Call `call_route_agent()`\n",
    "    3. Call `call_specialized_agents()`\n",
    "    4. assemble_final().\n",
    "\n",
    "    The document has already been stored in your state. Do not try to pass it explicitly.\n",
    "    \"\"\",\n",
    "    tools=[call_summary_agent, call_route_agent, call_specialized_agents, assemble_final],\n",
    "    planner=planner,\n",
    "    output_key=\"workflow_result\",\n",
    ")\n"
   ]
  },
  {
