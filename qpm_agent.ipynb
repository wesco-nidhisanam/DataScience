    "async def call_summary_agent(tool_context: ToolContext):\n",
    "    \"\"\"\n",
    "    Call the summary_agent. Uses the PDF already stored in state as 'document'.\n",
    "    Do NOT pass the Content object as an argument (automatic function calling expects simple types).\n",
    "    \"\"\"\n",
    "    print(\"--- TOOL CALL: call_summary_agent ---\")\n",
    "    # Ensure document exists\n",
    "    if \"document\" not in tool_context.state:\n",
    "        return {\"error\": \"No document in state\"}\n",
    "    agent_tool = AgentTool(agent=extract_summary_agent())\n",
    "    # Provide a simple textual instruction only\n",
    "    summary_output = await agent_tool.run_async(\n",
    "        args={\"request\": \"Detect presence of units, lots, notes from the provided PDF in context.\"},\n",
    "        tool_context=tool_context\n",
    "    )\n",
    "    # Store directly\n",
    "    tool_context.state[\"summary\"] = (\n",
    "        summary_output.model_dump() if hasattr(summary_output, \"model_dump\") else summary_output\n",
    "    )\n",
    "    print(\"[DEBUG:summary_agent] stored summary =\", summary_output)\n",
    "    return tool_context.state[\"summary\"]\n",
    "\n",
    "\n",
    "async def call_route_agent(tool_context: ToolContext):\n",
    "    print(\"--- TOOL CALL: call_route_agent ---\")\n",
    "\n",
    "    summary = tool_context.state.get(\"summary\", {})\n",
    "    print(summary)\n",
    "    # Normalize to dict\n",
    "    if hasattr(summary, \"model_dump\"):\n",
    "        summary = summary.model_dump()\n",
    "        \n",
    "    agents = []\n",
    "\n",
    "    if summary.get(\"lots_detected\", False):\n",
    "        agents.append(extract_lot_agent())\n",
    "    if summary.get(\"items_detected\", False):\n",
    "        agents.append(extract_unit_agent())\n",
    "    if summary.get(\"notes_detected\", False):\n",
    "        agents.append(extract_note_agent())\n",
    "    print(agents)\n",
    "    tool_context.state[\"specialized_agents\"] = agents\n",
    "    print(\"[DEBUG:route_agent] selected agents =\", [a.name for a in agents])\n",
    "    return [a.name for a in agents]\n",
    "\n",
    "\n",
    "async def call_specialized_agents(tool_context: ToolContext):\n",
    "    print(\"--- TOOL CALL: call_specialized_agents ---\")\n",
    "\n",
    "    # document = tool_context.state.get(\"document\")\n",
    "    agents = tool_context.state.get(\"specialized_agents\", [])\n",
    "    if not agents:\n",
    "        return \"No specialized agents to run.\"\n",
    "\n",
    "    fresh_agent_copies = [agent.copy(deep=True) for agent in agents]\n",
    "\n",
    "    \n",
    "    try:\n",
    "        parallel_agent = ParallelAgent(\n",
    "            name=\"parallel_specialized_agent\", sub_agents=fresh_agent_copies,\n",
    "            description=\"Runs multiple extractor agents in parallel to gather information from documents.\",\n",
    "        )\n",
    "    except Exception as e:\n",
    "        print(f\"ERROR creating ParallelAgent: {e}\")\n",
    "        return f\"Failed to create ParallelAgent: {e}\"\n",
    "    \n",
    "    agent_tool = AgentTool(agent=parallel_agent)\n",
    "\n",
    "    extraction_output = await agent_tool.run_async(\n",
    "        args={\"request\": \"extract the data from provided PDF in context.\"}, tool_context=tool_context\n",
    "    )\n",
    "    tool_context.state[\"extractions\"] = extraction_output\n",
    "    if isinstance(extraction_output, dict):\n",
    "        print(\"[DEBUG:specialized] extraction keys =\", list(extraction_output.keys()))\n",
    "    else:\n",
    "        print(\"[DEBUG:specialized] extraction output is not a dict:\", extraction_output)\n",
    "        \n",
    "    return extraction_output\n",
    "\n",
    "async def assemble_final(tool_context: ToolContext):\n",
    "    final_payload= {\n",
    "        \"summary\": tool_context.state.get(\"summary\"),\n",
    "        \"extractions\": tool_context.state.get(\"extractions\")\n",
    "    }\n",
    "    tool_context.state[\"workflow_result\"] = final_payload\n",
    "    print(\"[DEBUG:assemble_final] payload =\", list(final_payload.keys()))\n",
    "    return final_payload\n"
   ]
  },
