    "# ============================================================================\n",
    "# 3 SPECIALIZED AGENTS\n",
    "# ============================================================================\n",
    "\n",
    "def extract_summary_agent() -> LlmAgent:\n",
    "    \"\"\"Agent specialized in extracting summary .\"\"\"\n",
    "    return LlmAgent(\n",
    "        name=\"summary_extraction_agent\",\n",
    "        model=\"gemini-2.5-pro\",\n",
    "        instruction=summary_prompt,\n",
    "        planner=planner,\n",
    "        output_schema=SummaryResult,\n",
    "        disallow_transfer_to_parent=True,\n",
    "        disallow_transfer_to_peers=True,\n",
    "        output_key=\"summary\",\n",
    "        generate_content_config=types.GenerateContentConfig(\n",
    "        temperature=0.0)\n",
    "    )\n",
    "def extract_lot_agent() -> LlmAgent:\n",
    "    \"\"\"Agent specialized in extracting lot data.\"\"\"\n",
    "    return LlmAgent(\n",
    "        name=\"lots_extraction_agent\",\n",
    "        model=\"gemini-2.5-pro\",\n",
    "        instruction=Lot_prompt,\n",
    "        planner=planner,\n",
    "        output_schema=LotTable,\n",
    "        disallow_transfer_to_parent=True,\n",
    "        disallow_transfer_to_peers=True,\n",
    "        output_key=\"lots\",\n",
    "        generate_content_config=types.GenerateContentConfig(\n",
    "        temperature=0.0)\n",
    "    )\n",
    "    \n",
    "\n",
    "def extract_unit_agent() -> LlmAgent:\n",
    "    \"\"\"Agent specialized in extracting items data.\"\"\"\n",
    "    return LlmAgent(\n",
    "        name=\"units_extraction_agent\",\n",
    "        model=\"gemini-2.5-pro\",\n",
    "        instruction=Item_prompt,\n",
    "        planner=planner,\n",
    "        output_schema=ItemTable,\n",
    "        disallow_transfer_to_parent=True,\n",
    "        disallow_transfer_to_peers=True,\n",
    "        output_key=\"items\",\n",
    "        generate_content_config=types.GenerateContentConfig(\n",
    "        temperature=0.0)\n",
    "    )\n",
    "    \n",
    "\n",
    "def extract_note_agent() -> LlmAgent:\n",
    "    \"\"\"Agent specialized in extracting items data.\"\"\"\n",
    "    return LlmAgent(\n",
    "        name=\"notes_extraction_agent\",\n",
    "        model=\"gemini-2.5-pro\",\n",
    "        instruction=Notes_prompt,\n",
    "        planner=planner,\n",
    "        output_schema=NotesTable,\n",
    "        disallow_transfer_to_parent=True,\n",
    "        disallow_transfer_to_peers=True,\n",
    "        output_key=\"notes\",\n",
    "        generate_content_config=types.GenerateContentConfig(\n",
    "        temperature=0.0)\n",
    "    )"
   ]
